// Starter Worker config for ResolveScope.
// Keep this intentionally light; bind concrete resources once the app shape settles.

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "resolvescope",
  "main": "apps/worker/src/index.ts",
  "compatibility_date": "2026-03-31",
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_NAME": "ResolveScope",
    "AI_PROVIDER": "google",
    "AI_MODEL": "gemini-flash-lite-latest"
  }

  // Uncomment and replace placeholders as infrastructure is provisioned.
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "resolvescope",
  //     "database_id": "YOUR_D1_DATABASE_ID"
  //   }
  // ],
  // "r2_buckets": [
  //   {
  //     "binding": "ASSETS",
  //     "bucket_name": "resolvescope-assets"
  //   }
  // ],
  // "kv_namespaces": [
  //   {
  //     "binding": "CACHE",
  //     "id": "YOUR_KV_NAMESPACE_ID"
  //   }
  // ],
  // "queues": {
  //   "producers": [
  //     {
  //       "binding": "AI_JOBS",
  //       "queue": "resolvescope-ai-jobs"
  //     }
  //   ]
  // },
  // "durable_objects": {
  //   "bindings": [
  //     {
  //       "name": "REVIEW_ROOM",
  //       "class_name": "ReviewRoom"
  //     }
  //   ]
  // },
